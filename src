function TagBadge({ label, color }) {
  const colors = { gold:"rgba(245,158,11,0.2);#F59E0B", green:"rgba(16,185,129,0.2);#10B981", blue:"rgba(26,86,219,0.2);#60A5FA", red:"rgba(239,68,68,0.2);#EF4444" };

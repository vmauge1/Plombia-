function DevisModule({ devisCount, setDevisCount }) {
  const [prompt, setPrompt] = useState("");
  const [loading, setLoading] = useState(false);
  const [step, setStep] = useState(0);
  const [devis, setDevis] = useState(null);
  const [lines, setLines] = useState([]);
  const [toast, setToast] = useState("");
  const [clientName, setClientName] = useState("");
  const [clientAddr, setClientAddr] = useState("");

  const showToast = (msg) => { setToast(msg); setTimeout(()=>setToast(""),3000); };

  const STEPS = ["Identification des travaux","Calcul des fournitures","Estimation main d'œuvre","Application grille tarifaire"];

  const generate = async () => {
    if (!prompt.trim()) { showToast("⚠️ Décrivez d'abord le chantier !"); return; }
    setLoading(true); setDevis(null); setStep(0);
    for (let i = 0; i < 4; i++) { await new Promise(r=>setTimeout(r,420)); setStep(i+1); }
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method:"POST", headers:{"Content-Type":"application/json"},
        body: JSON.stringify({
          model:"claude-sonnet-4-20250514", max_tokens:1000,
          system:`Tu es un expert en plomberie/chauffage français. Génère un devis JSON uniquement, sans texte autour.
Format: {"title":"Titre court","client_name":"Nom client","client_address":"Adresse","lines":[{"desc":"Description","qty":1,"unit":"forfait","pu_ht":150,"tva":10}],"notes":"Conditions..."}
Règles: prix marché français 2025 (plombier 60-90€/h HT, chauffagiste 70-100€/h HT), TVA 10% rénovation / 20% matériel seul, 4-8 lignes réalistes, unités: forfait/h/u/ml/m2`,
          messages:[{role:"user",content:`Chantier: ${prompt}`}]
        })
      });
      const data = await res.json();
      const text = data.content?.map(c=>c.text||"").join("").replace(/```json|```/g,"").trim();
      const parsed = JSON.parse(text);
      setDevis(parsed);
      setLines(parsed.lines.map((l,i)=>({...l,id:i})));
      setClientName(parsed.client_name||"");
      setClientAddr(parsed.client_address||"");
      setDevisCount(n=>n+1);
    } catch {
      const fallback = { title:"Travaux Plomberie", client_name:"M./Mme Client", client_address:"", notes:"Paiement: 30% commande, solde réception. Garantie MO 1 an. Valable 30 jours.", lines:[
        {desc:"Déplacement et diagnostic",qty:1,unit:"forfait",pu_ht:65,tva:20},
        {desc:"Main d'œuvre plombier qualifié",qty:3,unit:"h",pu_ht:78,tva:10},
        {desc:"Fournitures et matériaux",qty:1,unit:"forfait",pu_ht:185,tva:20},
        {desc:"Mise en service et tests",qty:1,unit:"forfait",pu_ht:55,tva:10},
      ]};
      setDevis(fallback);
      setLines(fallback.lines.map((l,i)=>({...l,id:i})));
      setClientName(fallback.client_name);
      setClientAddr("");
      setDevisCount(n=>n+1);
    }
    setLoading(false);
  };

  const updateLine = (id, field, val) => setLines(ls=>ls.map(l=>l.id===id?{...l,[field]:field==="qty"||field==="pu_ht"?parseFloat(val)||0:val}:l));
  const addLine = () => setLines(ls=>[...ls,{id:Date.now(),desc:"Nouvelle prestation",qty:1,unit:"h",pu_ht:75,tva:10}]);
  const removeLine = (id) => setLines(ls=>ls.filter(l=>l.id!==id));

  const subtotal = lines.reduce((s,l)=>s+(l.qty*l.pu_ht),0);
  const tvaAmt = lines.reduce((s,l)=>s+(l.qty*l.pu_ht*(l.tva/100)),0);
  const ttc = subtotal+tvaAmt;
  const fmt = (n) => n.toLocaleString("fr-FR",{minimumFractionDigits:2,maximumFractionDigits:2})+" €";
  const today = new Date().toLocaleDateString("fr-FR",{day:"2-digit",month:"long",year:"numeric"});
  const numStr = `DEV-${new Date().getFullYear()}-${String(devisCount).padStart(3,"0")}`;

  return (
    <div style={{display:"flex",flexDirection:"column",gap:16}}>
      <div>
        <div style={styles.pageTitle}>Générateur de <span style={{color:COLORS.cyan}}>Devis IA</span></div>
        <div style={styles.pageSub}>Décrivez le chantier — l'IA génère un devis complet en quelques secondes</div>
      </div>

      {/* AI INPUT */}
      <div style={{...styles.card, position:"relative", borderTop:`2px solid ${COLORS.cyan}`}}>
        <div style={styles.label}>⚡ IA Prête</div>
        <textarea
          style={{...styles.textarea, minHeight:80, paddingRight:120}}
          placeholder="Ex: Remplacement chauffe-eau 200L thermodynamique, cave difficile d'accès, Lyon 69003..."
          value={prompt} onChange={e=>setPrompt(e.target.value)}
          onKeyDown={e=>e.key==="Enter"&&e.ctrlKey&&generate()}
        />
        <button style={{...styles.btn("primary"), position:"absolute", right:24, bottom:56}} onClick={generate} disabled={loading}>
          {loading ? "⏳" : "⚡"} Générer
        </button>
        <div style={{display:"flex",gap:6,flexWrap:"wrap",marginTop:10}}>
          {EXAMPLES.map(ex=>(
            <span key={ex.label} style={styles.chip} onClick={()=>setPrompt(ex.prompt)}>
              {ex.emoji} {ex.label}
            </span>
          ))}
        </div>
      </div>

      {/* LOADING */}
      {loading && (
        <div style={{...styles.card, textAlign:"center", padding:24}}>
          <div style={{width:32,height:32,border:`3px solid rgba(6,182,212,0.2)`,borderTopColor:COLORS.cyan,borderRadius:"50%",animation:"spin 0.8s linear infinite",margin:"0 auto 12px"}}/>
          <style>{`@keyframes spin{to{transform:rotate(360deg)}}`}</style>
          <div style={{fontSize:13,color:COLORS.gray,marginBottom:8}}>L'IA analyse votre description…</div>
          {STEPS.map((s,i)=>(
            <div key={s} style={{fontSize:12, padding:"3px 0", color: i<step?COLORS.green : i===step-1?COLORS.cyan : COLORS.gray2}}>
              {i<step?"✓":i===step-1?"⟳":"·"} {s}
            </div>
          ))}
        </div>
      )}

      {/* DEVIS RESULT */}
      {devis && !loading && (
        <div style={{...styles.card, padding:0, overflow:"hidden"}}>
          {/* Header */}
          <div style={{background:`linear-gradient(135deg,${COLORS.card2},${COLORS.card})`,padding:"16px 20px",display:"flex",justifyContent:"space-between",alignItems:"flex-start",borderBottom:`1px solid rgba(255,255,255,0.07)`}}>
            <div>
              <div style={{fontSize:16,fontWeight:800}}>Devis — {devis.title}</div>
              <div style={{fontSize:11,color:COLORS.gray,marginTop:2}}>Créé le {today} · Valable 30 jours</div>
            </div>
            <div style={{background:"rgba(6,182,212,0.15)",border:`1px solid rgba(6,182,212,0.3)`,color:COLORS.cyan,padding:"6px 14px",borderRadius:8,fontSize:12,fontWeight:800}}>{numStr}</div>
          </div>

          <div style={{padding:"16px 20px",display:"flex",flexDirection:"column",gap:14}}>
            {/* Info grid */}
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
              {[["👷 Votre entreprise",["Jean-Marc Dupont Plomberie","06 12 34 56 78 · SIRET: 123 456 789"]],["🏠 Client",[clientName,clientAddr]]].map(([lbl,vals],i)=>(
                <div key={lbl} style={{background:"rgba(255,255,255,0.03)",border:`1px solid rgba(255,255,255,0.07)`,borderRadius:8,padding:12}}>
                  <div style={{fontSize:9,fontWeight:700,letterSpacing:2,textTransform:"uppercase",color:COLORS.gray2,marginBottom:6}}>{lbl}</div>
                  {i===1 ? <>
                    <input style={styles.input} value={clientName} onChange={e=>setClientName(e.target.value)} placeholder="Nom du client"/>
                    <input style={{...styles.input,fontSize:11,color:COLORS.gray,marginTop:3}} value={clientAddr} onChange={e=>setClientAddr(e.target.value)} placeholder="Adresse du chantier"/>
                  </> : vals.map((v,j)=>(
                    <div key={j} style={{fontSize:j===0?13:11,color:j===0?COLORS.white:COLORS.gray,marginBottom:j===0?2:0}}>{v}</div>
                  ))}
                </div>
              ))}
            </div>

            {/* Table */}
            <div style={{overflowX:"auto"}}>
              <table style={{width:"100%",borderCollapse:"collapse"}}>
                <thead>
                  <tr style={{background:"rgba(255,255,255,0.03)"}}>
                    {["Description","Qté","Unité","P.U. HT","TVA","Total HT",""].map((h,i)=>(
                      <th key={i} style={{padding:"8px 10px",fontSize:9,fontWeight:700,textTransform:"uppercase",letterSpacing:1.5,color:COLORS.gray2,textAlign:i>=4?"right":"left",borderBottom:`1px solid rgba(255,255,255,0.07)`,whiteSpace:"nowrap"}}>{h}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {lines.map(line=>(
                    <tr key={line.id} style={{borderBottom:`1px solid rgba(255,255,255,0.04)`}}>
                      <td style={{padding:"10px 10px"}}><input style={{...styles.input,fontSize:13}} value={line.desc} onChange={e=>updateLine(line.id,"desc",e.target.value)}/></td>
                      <td style={{padding:"10px 10px"}}><input type="number" style={{...styles.input,width:50,textAlign:"center"}} value={line.qty} onChange={e=>updateLine(line.id,"qty",e.target.value)}/></td>
                      <td style={{padding:"10px 10px"}}>
                        <select style={styles.select} value={line.unit} onChange={e=>updateLine(line.id,"unit",e.target.value)}>
                          {["forfait","h","u","ml","m2"].map(u=><option key={u} value={u}>{u}</option>)}
                        </select>
                      </td>
                      <td style={{padding:"10px 10px"}}><input type="number" style={{...styles.input,width:75,textAlign:"right"}} value={line.pu_ht} onChange={e=>updateLine(line.id,"pu_ht",e.target.value)}/></td>
                      <td style={{padding:"10px 10px",textAlign:"right"}}>
                        <select style={{...styles.select,textAlign:"right"}} value={line.tva} onChange={e=>updateLine(line.id,"tva",parseFloat(e.target.value))}>
                          {[5.5,10,20].map(t=><option key={t} value={t}>{t}%</option>)}
                        </select>
                      </td>
                      <td style={{padding:"10px 10px",textAlign:"right",fontWeight:700,fontSize:13,whiteSpace:"nowrap"}}>{fmt(line.qty*line.pu_ht)}</td>
                      <td style={{padding:"10px 6px",textAlign:"center"}}>
                        <button onClick={()=>removeLine(line.id)} style={{background:"none",border:"none",color:COLORS.gray2,cursor:"pointer",fontSize:14,padding:2}}>✕</button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            <button onClick={addLine} style={{background:"rgba(255,255,255,0.04)",border:`1px dashed rgba(255,255,255,0.15)`,color:COLORS.gray,padding:"9px",borderRadius:8,cursor:"pointer",fontSize:12,width:"100%",transition:"all 0.15s"}}>
              + Ajouter une ligne
            </button>

            {/* Totals */}
            <div style={{display:"flex",justifyContent:"flex-end"}}>
              <div style={{width:260,border:`1px solid rgba(255,255,255,0.08)`,borderRadius:10,overflow:"hidden"}}>
                {[["Sous-total HT",fmt(subtotal),COLORS.white],["TVA",fmt(tvaAmt),COLORS.gray]].map(([k,v,c])=>(
                  <div key={k} style={{display:"flex",justifyContent:"space-between",padding:"9px 14px",borderBottom:`1px solid rgba(255,255,255,0.05)`}}>
                    <span style={{fontSize:12,color:COLORS.gray}}>{k}</span>
                    <span style={{fontSize:12,fontWeight:600,color:c}}>{v}</span>
                  </div>
                ))}
                <div style={{display:"flex",justifyContent:"space-between",padding:"12px 14px",background:"rgba(6,182,212,0.1)"}}>
                  <span style={{fontSize:13,fontWeight:800}}>TOTAL TTC</span>
                  <span style={{fontSize:16,fontWeight:800,color:COLORS.cyan}}>{fmt(ttc)}</span>
                </div>
              </div>
            </div>

            {/* Notes */}
            <div style={{background:"rgba(255,255,255,0.03)",border:`1px solid rgba(255,255,255,0.07)`,borderRadius:8,padding:12,fontSize:12,color:COLORS.gray,lineHeight:1.7}}>
              {devis.notes}
            </div>

            {/* Actions */}
            <div style={{display:"flex",gap:8,flexWrap:"wrap",paddingTop:12,borderTop:`1px solid rgba(255,255,255,0.06)`}}>
              <button style={styles.btn("primary")} onClick={()=>showToast("📥 PDF prêt — disponible dans la version complète")}>📥 PDF</button>
              <button style={styles.btn("success")} onClick={()=>showToast("📧 Email envoyé au client !")}>📧 Email client</button>
              <button style={styles.btn("ghost")} onClick={()=>showToast("⎘ Devis dupliqué !")}>⎘ Dupliquer</button>
              <button style={{...styles.btn("ghost"),marginLeft:"auto"}} onClick={()=>{setDevis(null);setPrompt("");}}>+ Nouveau</button>
            </div>
          </div>
        </div>
      )}

      {/* Toast */}
      {toast && (
        <div style={{position:"fixed",bottom:20,right:20,background:COLORS.card2,border:`1px solid rgba(6,182,212,0.3)`,borderRadius:10,padding:"12px 18px",fontSize:13,boxShadow:"0 16px 40px rgba(0,0,0,0.4)",zIndex:1000,animation:"fadeIn 0.2s ease"}}>
          <style>{`@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}`}</style>
          {toast}
        </div>
      )}
    </div>
  );
}


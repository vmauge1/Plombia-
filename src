function FacturesModule() {
  const statusStyle = { paid:"rgba(16,185,129,0.15);#10B981", pending:"rgba(245,158,11,0.15);#F59E0B", late:"rgba(239,68,68,0.15);#EF4444" };
  return (
    <div style={{display:"flex",flexDirection:"column",gap:16}}>
      <div>
        <div style={styles.pageTitle}>Mes <span style={{color:COLORS.cyan}}>Factures</span></div>
        <div style={styles.pageSub}>Suivi des paiements</div>
      </div>
      <div style={{...styles.card,padding:0,overflow:"hidden"}}>
        <table style={{width:"100%",borderCollapse:"collapse"}}>
          <thead>
            <tr style={{background:"rgba(255,255,255,0.04)"}}>
              {["N° Facture","Client","Travaux","Montant TTC","Date","Statut"].map(h=>(
                <th key={h} style={{padding:"10px 14px",fontSize:9,fontWeight:700,textTransform:"uppercase",letterSpacing:1.5,color:COLORS.gray2,textAlign:"left",borderBottom:`1px solid rgba(255,255,255,0.07)`}}>{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {FACTURES.map(f=>{
              const [bg,fg] = statusStyle[f.status].split(";");
              return (
                <tr key={f.num} style={{borderBottom:`1px solid rgba(255,255,255,0.04)`,cursor:"pointer"}}>
                  <td style={{padding:"12px 14px",fontSize:12,fontWeight:800,color:COLORS.cyan}}>{f.num}</td>
                  <td style={{padding:"12px 14px",fontSize:13}}>{f.client}</td>
                  <td style={{padding:"12px 14px",fontSize:12,color:COLORS.gray}}>{f.desc}</td>
                  <td style={{padding:"12px 14px",fontSize:13,fontWeight:700}}>{f.montant}</td>
                  <td style={{padding:"12px 14px",fontSize:12,color:COLORS.gray}}>{f.date}</td>
                  <td style={{padding:"12px 14px"}}><span style={{background:bg,color:fg,fontSize:10,fontWeight:700,padding:"4px 10px",borderRadius:6}}>{f.label}</span></td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  );
}

function PlanningModule() {
  const typeColor = { urgent:["rgba(245,158,11,0.12)",COLORS.gold], done:["rgba(16,185,129,0.1)","#059669"], "":["rgba(6,182,212,0.1)",COLORS.cyan] };
  return (
    <div style={{display:"flex",flexDirection:"column",gap:16}}>
      <div>
        <div style={styles.pageTitle}>Mon <span style={{color:COLORS.cyan}}>Planning</span></div>
        <div style={styles.pageSub}>Semaine du 3 au 7 mars 2025</div>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"repeat(5,1fr)",gap:10}}>
        {PLANNING.map(day=>(
          <div key={day.day} style={styles.card}>
            <div style={{fontSize:10,fontWeight:800,textTransform:"uppercase",letterSpacing:1.5,color:COLORS.gray2,marginBottom:10}}>{day.day}</div>
            {day.items.map((item,i)=>{
              const [bg,border] = typeColor[item.type]||typeColor[""];
              return (
                <div key={i} style={{background:bg,borderLeft:`3px solid ${border}`,borderRadius:6,padding:"8px 10px",marginBottom:6}}>
                  <div style={{fontSize:10,color:COLORS.gray,marginBottom:2}}>{item.t}</div>
                  <div style={{fontSize:12,fontWeight:700}}>{item.title}</div>
                  <div style={{fontSize:11,color:COLORS.gray,marginTop:1}}>{item.client}</div>
                </div>
              );
            })}
          </div>
        ))}
      </div>
    </div>
  );
}

